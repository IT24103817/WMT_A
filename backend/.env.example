# --- Server ---
PORT=5000
NODE_ENV=development

# --- MongoDB Atlas ---
# From Atlas: Cluster -> Connect -> Drivers -> copy the connection string
MONGO_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/gemmarket?retryWrites=true&w=majority

# --- JWT ---
JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRES_IN=7d

# --- Admin seed (used by `npm run seed:admin`) ---
ADMIN_NAME=GemMarket Admin
ADMIN_EMAIL=admin@gemmarket.local
ADMIN_PASSWORD=ChangeMe!2026

# --- Cloudinary ---
# Sign up at cloudinary.com -> Dashboard -> Account Details
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Stripe (test mode) ---
# Sign up at stripe.com -> Developers -> API keys
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# --- CORS ---
# Comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,exp://
