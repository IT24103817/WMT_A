# STANDARD IGNORES
node_modules/
.env
.env.local
.expo/
.expo-shared/
dist/
build/
*.log
.DS_Store
ios/
android/
.vscode/
coverage/

# ===== EXCLUDE ALL FILES BY DEFAULT =====
# Track ONLY backend and frontend code files for marketplace/offer components

# EXCLUDE ALL DOCUMENTATION & MARKDOWN
*.md
docs/
__MACOSX/
e2e/

# BACKEND - MARKETPLACE/OFFER ONLY
backend/**
!backend/controllers/marketplaceController.js
!backend/controllers/offerController.js
!backend/controllers/paymentController.js
!backend/controllers/orderController.js
!backend/controllers/inventoryController.js

!backend/models/Listing.js
!backend/models/Offer.js
!backend/models/Gem.js
!backend/models/Order.js
!backend/models/Payment.js
!backend/models/User.js
!backend/models/Review.js
!backend/models/Bid.js

!backend/routes/marketplace.js
!backend/routes/offers.js
!backend/routes/payments.js
!backend/routes/orders.js

!backend/utils/finalizeSale.js
!backend/utils/generateOrderNumber.js
!backend/utils/lazyCloseBids.js

!backend/middleware/upload.js
!backend/middleware/auth.js
!backend/middleware/adminOnly.js

!backend/config/cloudinary.js
!backend/config/db.js

!backend/package.json
!backend/server.js

# MOBILE FRONTEND - MARKETPLACE/OFFER ONLY
mobile/**
!mobile/src/screens/marketplace/
!mobile/src/screens/offers/
!mobile/src/screens/orders/
!mobile/src/screens/payment/

!mobile/src/api/client.js
!mobile/src/api/index.js
!mobile/src/utils/upload.js

!mobile/src/context/AuthContext.js
!mobile/src/stripe/index.native.js
!mobile/src/stripe/index.web.js
!mobile/src/theme.js

!mobile/package.json
!mobile/app.json
!mobile/App.js
!mobile/babel.config.js
