# STANDARD IGNORES
node_modules/
.env
.env.local
.expo/
.expo-shared/
dist/
build/
*.log
.DS_Store
ios/
android/
.vscode/
coverage/

# ===== EXCLUDE ALL FILES BY DEFAULT =====
